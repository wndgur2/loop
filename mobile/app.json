{
  "expo": {
    "name": "Loop",
    "slug": "loop",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loop",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.loop.app"
    },
    "android": {
      "package": "com.loop.app",
      "adaptiveIcon": {
        "backgroundColor": "#FBF1E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DD8A4F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 130,
          "android": {
            "backgroundColor": "#DD8A4F",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 130
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "81a99a05-77a6-4e0c-99e0-ff5be218a8a7"
      }
    },
    "owner": "wndgur2"
  }
}
