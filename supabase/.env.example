# Edge Function 전용 비밀값 — 클라이언트에 절대 노출 금지 (CLAUDE.md §6).
#
# 로컬 실행: 이 파일을 복사해 supabase/functions/.env 로 만들고 값 채움
#            (supabase functions serve --env-file supabase/functions/.env)
# 배포:      supabase secrets set ANTHROPIC_API_KEY=...
#
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY 는 배포·로컬에서 런타임이 자동 주입하므로
# 보통 별도 설정 불필요. 직접 넣어야 할 때만 채운다.

# --- LLM 프로바이더 선택 (어댑터 패턴) ---
# anthropic(기본) | openai | gemini. 고른 프로바이더의 키만 채우면 된다.
LLM_PROVIDER=anthropic

# 선택된 프로바이더의 키 (해당 프로바이더만 필요)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# 모델 오버라이드 (선택)
# 우선순위: 프로바이더 전용({PROVIDER}_MODEL) → 공통 CHAT_MODEL → 프로바이더 기본값.
# 아래에서 쓰려는 모델 1줄의 주석만 풀면 된다.

# 활성 프로바이더 무관 공통 모델 (전용값 없을 때 적용)
# CHAT_MODEL=

# Anthropic (기본 claude-opus-4-8). 정본: claude-api 스킬
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MODEL=claude-opus-4-7
# ANTHROPIC_MODEL=claude-opus-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI (기본 gpt-5.4). 
# OPENAI_MODEL=gpt-5.5           # 최상위 — 코딩/전문작업, 1M context
# OPENAI_MODEL=gpt-5.4           # 균형 — 더 저렴, 1M context
# OPENAI_MODEL=gpt-5.4-mini      # 최강 mini — 저비용, 400K context

# Gemini (기본 gemini-3.5-flash).
# GEMINI_MODEL=gemini-3.1-pro-preview   # 최상위 추론 (preview)
# GEMINI_MODEL=gemini-3.5-flash         # stable flash 최신 — 가장 지능적
# GEMINI_MODEL=gemini-3.1-flash-lite    # 저비용 (stable)
# GEMINI_MODEL=gemini-2.5-pro           # 이전 세대 pro (stable)
# GEMINI_MODEL=gemini-2.5-flash         # 이전 세대 flash (stable)

# --- 결제/구독 (RevenueCat) — adr-0006 ---
# RevenueCat 대시보드 webhook의 Authorization 헤더에 넣는 값과 동일해야 한다.
# 이 시크릿으로 revenuecat-webhook 함수가 호출 진위를 검증한다(불일치 시 401).
REVENUECAT_WEBHOOK_SECRET=

# Loopie 주간 사용량 한도(게이팅). 무료 = 주 N회, Pro = N × 배수(공정사용, 남용만 차단).
# 비우면 기본값(free=30, multiplier=20) 사용.
LOOPIE_FREE_WEEKLY_LIMIT=30
LOOPIE_PRO_LIMIT_MULTIPLIER=20
