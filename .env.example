# 이 파일을 복사해 .env 로 만들고 값을 채우세요. .env 는 절대 커밋하지 않습니다.

# --- 클라이언트(앱)에 노출되어도 되는 값 (EXPO_PUBLIC_ 접두사 필수) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- 서버(Edge Function) 전용 비밀값 — 클라이언트에 절대 노출 금지 ---
# 아래는 Supabase Edge Function secret 으로 설정합니다 (supabase secrets set ...)
ANTHROPIC_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
